  <!-- variant dispatch: emit only the selected linkage -->
  <xacro:if value="${variant == 'left_ankle'}">
    <xacro:igris_parallel_left_ankle/>
  </xacro:if>
  <xacro:if value="${variant == 'right_ankle'}">
    <xacro:igris_parallel_right_ankle/>
  </xacro:if>
  <xacro:if value="${variant == 'left_wrist'}">
    <xacro:igris_parallel_left_wrist/>
  </xacro:if>
  <xacro:if value="${variant == 'right_wrist'}">
    <xacro:igris_parallel_right_wrist/>
  </xacro:if>
  <xacro:if value="${variant == 'waist'}">
    <xacro:igris_parallel_waist/>
  </xacro:if>
