<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="igris_c_v2">
  <!-- ===================== 1. Parameters (xacro args) ===================== -->
  <xacro:arg name="base_type" default="torso"/>
  <xacro:arg name="parallel" default="false"/>
  <xacro:arg name="end_effector" default="dummy"/>
  <!-- ===================== 2. Constants (xacro properties) ===================== -->
  <xacro:property name="random_rgba" value="0.0706 0.0706 0.0706 0.7"/>
  <xacro:property name="base_type_value" value="$(arg base_type)"/>
  <xacro:property name="parallel_enabled" value="${str('$(arg parallel)').lower() == 'true'}"/>
  <!-- ===================== 3. Reusable macro definitions ===================== -->
  <xacro:macro name="igris_parallel_waist">
    <link name="dummy_1_x"/>
    <link name="dummy_1_y"/>
    <link name="dummy_2_x"/>
    <link name="dummy_2_y"/>
