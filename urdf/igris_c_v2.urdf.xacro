      <inertial>
        <mass value="0.043"/>
        <origin xyz="-0.01470 -0.00883 -0.00167"/>
        <inertia ixx="0.00001" ixy="0.00000" ixz="0.00000" iyy="0.00004" iyz="0.00000" izz="0.00003"/>
