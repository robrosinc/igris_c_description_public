<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="random_rgba" value="0.0706 0.0706 0.0706 0.7"/>
  <xacro:property name="gripper_rgba" value="0.58 0.58 0.60 1"/>
  <xacro:property name="mesh_prefix" value="package://igris_c_description/meshes/igris_c_end_effector"/>

  <xacro:macro name="igris_end_effector" params="hand_type left_parent:=Link_Wrist_Pitch_Left right_parent:=Link_Wrist_Pitch_Right">
    <xacro:if value="${hand_type == 'dummy'}">
      <xacro:igris_dummy_end_effector side="Left" parent="${left_parent}"/>
      <xacro:igris_dummy_end_effector side="Right" parent="${right_parent}"/>
    </xacro:if>

    <xacro:if value="${hand_type == 'hand'}">
      <xacro:igris_hand_end_effector side="Left" parent="${left_parent}"/>
      <xacro:igris_hand_end_effector side="Right" parent="${right_parent}"/>
    </xacro:if>

    <xacro:if value="${hand_type == '1dof'}">
      <xacro:igris_1dof_gripper_end_effector side="Left" parent="${left_parent}"/>
      <xacro:igris_1dof_gripper_end_effector side="Right" parent="${right_parent}"/>
    </xacro:if>

    <xacro:if value="${hand_type == 'em'}">
      <xacro:igris_em_gripper_end_effector side="Left" parent="${left_parent}"/>
      <xacro:igris_em_gripper_end_effector side="Right" parent="${right_parent}"/>
    </xacro:if>
  </xacro:macro>

  <xacro:macro name="igris_dummy_end_effector" params="side parent">
    <link name="${side}_Hand">
      <inertial>
        <xacro:if value="${side == 'Left'}">
          <mass value="0.333" />
          <origin xyz="0.00910 0.00371 0.07839" />
          <inertia ixx="0.00081" ixy="-0.00004" ixz="0.00012" iyy="0.00117" iyz="0.00005" izz="0.00042" />
        </xacro:if>
        <xacro:unless value="${side == 'Left'}">
          <mass value="0.333" />
          <origin xyz="0.00910 -0.00371 0.07839" />
          <inertia ixx="0.00081" ixy="0.00004" ixz="0.00012" iyy="0.00117" iyz="-0.00005" izz="0.00042" />
        </xacro:unless>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="${mesh_prefix}/hand/Hand_${side}.stl" scale="0.01 0.01 0.01"/>
        </geometry>
        <material name="random">
          <color rgba="${random_rgba}" />
        </material>
      </visual>
      <collision>
        <origin xyz="0.02 0.0 0.1" rpy="0 0 0"/>
        <geometry>
          <box size="0.15 0.05 0.2"/>
        </geometry>
      </collision>
    </link>

    <joint name="${side}_Hand" type="fixed">
      <parent link="${parent}" />
      <child link="${side}_Hand" />
      <xacro:if value="${side == 'Left'}">
        <origin xyz="0 0.0109 -0.024" rpy="3.14 0 0" />
      </xacro:if>
      <xacro:unless value="${side == 'Left'}">
        <origin xyz="0 -0.0109 -0.024" rpy="3.14 0 0" />
      </xacro:unless>
    </joint>
  </xacro:macro>

  <xacro:macro name="igris_em_gripper_end_effector" params="side parent">
    <link name="EM_Gripper_${side}">
      <inertial>
        <xacro:if value="${side == 'Left'}">
          <mass value="0.324" />
          <origin xyz="0 -0.00986 -0.05139" />
          <inertia ixx="0.00016" ixy="-0.00000" ixz="0.00000" iyy="0.00011" iyz="0.00000" izz="0.00014" />
        </xacro:if>
        <xacro:unless value="${side == 'Left'}">
          <mass value="0.324" />
          <origin xyz="0 0.00986 -0.05139" />
          <inertia ixx="0.00016" ixy="0.00000" ixz="0.00000" iyy="0.00011" iyz="0.00000" izz="0.00014" />
        </xacro:unless>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="${mesh_prefix}/em_gripper/EM_Gripper_${side}.stl" scale="0.01 0.01 0.01"/>
        </geometry>
        <material name="random">
          <color rgba="${gripper_rgba}" />
        </material>
      </visual>
    </link>

    <joint name="EM_Gripper_${side}" type="fixed">
      <parent link="${parent}" />
      <child link="EM_Gripper_${side}" />
      <origin xyz="0 0 -0.024" rpy="0 0 0" />
    </joint>
  </xacro:macro>

  <xacro:macro name="igris_1dof_gripper_end_effector" params="side parent">
    <link name="1_DoF_Fixed_Gripper_${side}">
      <inertial>
        <xacro:if value="${side == 'Left'}">
          <mass value="0.271" />
          <origin xyz="0.00396 0.00377 -0.05310" />
          <inertia ixx="0.00033" ixy="-0.00001" ixz="-0.00003" iyy="0.00040" iyz="-0.00004" izz="0.00021" />
        </xacro:if>
        <xacro:unless value="${side == 'Left'}">
          <mass value="0.271" />
          <origin xyz="0.00396 0.00377 -0.05310" />
          <inertia ixx="0.00033" ixy="-0.00001" ixz="-0.00003" iyy="0.00040" iyz="-0.00004" izz="0.00021" />
        </xacro:unless>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="${mesh_prefix}/1_dof_gripper/1DG_${side}_Fixed.stl" scale="0.01 0.01 0.01"/>
        </geometry>
        <material name="random">
          <color rgba="${gripper_rgba}" />
        </material>
      </visual>
    </link>

    <link name="1_DoF_Moving_Gripper_${side}">
      <inertial>
        <xacro:if value="${side == 'Left'}">
          <mass value="0.093" />
          <origin xyz="-0.00028 -0.00857 -0.04908" />
          <inertia ixx="0.00007" ixy="0.00000" ixz="0.00000" iyy="0.00009" iyz="-0.00001" izz="0.00004" />
        </xacro:if>
        <xacro:unless value="${side == 'Left'}">
          <mass value="0.093" />
          <origin xyz="-0.00028 0.00857 -0.04908" />
          <inertia ixx="0.00007" ixy="0.00000" ixz="0.00000" iyy="0.00009" iyz="-0.00001" izz="0.00004" />
        </xacro:unless>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="${mesh_prefix}/1_dof_gripper/1DG_${side}_Moving.stl" scale="0.01 0.01 0.01"/>
        </geometry>
        <material name="random">
          <color rgba="${gripper_rgba}" />
        </material>
      </visual>
    </link>

    <joint name="1_DoF_Fixed_Gripper_${side}" type="fixed">
      <parent link="${parent}" />
      <child link="1_DoF_Fixed_Gripper_${side}" />
      <origin xyz="0 0 -0.024" rpy="0 0 0" />
    </joint>

    <joint name="1_DoF_Moving_Gripper_${side}" type="revolute">
      <parent link="1_DoF_Fixed_Gripper_${side}" />
      <child link="1_DoF_Moving_Gripper_${side}" />
      <xacro:if value="${side == 'Left'}">
        <origin xyz="0 0.02625 -0.04225" rpy="0 0 0" />
        <axis xyz="1 0 0" />
        <limit lower="0" upper="1.74533" effort="1000" velocity="100.0" />
      </xacro:if>
      <xacro:unless value="${side == 'Left'}">
        <origin xyz="0 -0.02625 -0.04225" rpy="0 0 0" />
        <axis xyz="1 0 0" />
        <limit lower="-1.74533" upper="0" effort="1000" velocity="100.0" />
      </xacro:unless>
    </joint>
  </xacro:macro>

  <xacro:macro name="igris_hand_end_effector" params="side parent">
    <link name="${side}_Hand">
      <inertial>
        <xacro:if value="${side == 'Left'}">
          <mass value="0.333" />
          <origin xyz="0.00910 0.00371 0.07839" />
          <inertia ixx="0.00081" ixy="-0.00004" ixz="0.00012" iyy="0.00117" iyz="0.00005" izz="0.00042" />
        </xacro:if>
        <xacro:unless value="${side == 'Left'}">
          <mass value="0.333" />
          <origin xyz="0.00910 -0.00371 0.07839" />
          <inertia ixx="0.00081" ixy="0.00004" ixz="0.00012" iyy="0.00117" iyz="-0.00005" izz="0.00042" />
        </xacro:unless>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="${mesh_prefix}/hand/Palm_${side}.stl" scale="0.01 0.01 0.01" />
        </geometry>
        <material name="random">
          <color rgba="${random_rgba}" />
        </material>
      </visual>
      <collision>
        <geometry>
          <mesh filename="${mesh_prefix}/hand/Palm_${side}.stl" scale="0.01 0.01 0.01" />
        </geometry>
      </collision>
    </link>

    <joint name="${side}_Hand" type="fixed">
      <parent link="${parent}" />
      <child link="${side}_Hand" />
      <xacro:if value="${side == 'Left'}">
        <origin xyz="0 0.0109 -0.024" rpy="3.14 0 0" />
      </xacro:if>
      <xacro:unless value="${side == 'Left'}">
        <origin xyz="0 -0.0109 -0.024" rpy="3.14 0 0" />
      </xacro:unless>
    </joint>

    <xacro:igris_hand_finger_chain side="${side}" parent="${side}_Hand" part="Thumb_Proximal" child="Thumb_Middle"
                                   joint_name="0_Joint_Thumb_Proximal" xyz="${side == 'Left' and '0.026 0.0132 0.0299' or '0.026 -0.0132 0.0299'}"
                                   rpy="${side == 'Left' and '-0.087265666 0 0' or '0.087265666 0 0'}"
                                   axis="0 0 1"
                                   lower="${side == 'Left' and '0' or '-1.727875959'}"
                                   upper="${side == 'Left' and '1.727875959' or '0'}"
                                   mass="0.01" inertia="1e-5" mesh="${side == 'Left' and 'Thumb_Proximal_Left' or 'Thumb_Proximal_Right'}"/>
    <xacro:igris_hand_finger_chain side="${side}" parent="${side}_Thumb_Proximal" part="Thumb_Middle" child="Thumb_Distal"
                                   joint_name="1_Joint_Thumb_Middle" xyz="${side == 'Left' and '0.0230 0.0036 0.015' or '0.0230 -0.0035 0.015'}"
                                   rpy="-1.221731311 0 -1.570796752"
                                   axis="1 0 0"
                                   lower="0" upper="1.221730476"
                                   mass="0.008" inertia="8e-6" mesh="${side == 'Left' and 'Thumb_Middle_Left' or 'Thumb_Middle_Right'}"/>
    <xacro:igris_hand_finger_leaf side="${side}" parent="${side}_Thumb_Middle" part="Thumb_Distal"
                                  joint_name="2_Joint_Thumb_Distal" xyz="0 -0.001 0.04" rpy="0 0 0"
                                  axis="1 0 0" lower="0" upper="1.570796327"
                                  mass="0.006" inertia="6e-6" mesh="${side == 'Left' and 'Thumb_Distal_Left' or 'Thumb_Distal_Right'}"/>

    <xacro:igris_hand_finger_chain side="${side}" parent="${side}_Hand" part="Index_Middle" child="Index_Distal"
                                   joint_name="3_Joint_Index_Middle" xyz="${side == 'Left' and '0.0305 -0.002 0.101' or '0.0305 0.002 0.101'}"
                                   rpy="${side == 'Left' and '0 0 3.141592654' or '0 0 0'}"
                                   axis="1 0 0" lower="0" upper="1.570796327"
                                   mass="0.008" inertia="8e-6" mesh="Finger_Middle"/>
    <xacro:igris_hand_finger_leaf side="${side}" parent="${side}_Index_Middle" part="Index_Distal"
                                  joint_name="4_Joint_Index_Distal" xyz="0 -0.001 0.04" rpy="0 0 0"
                                  axis="1 0 0" lower="0" upper="1.570796327"
                                  mass="0.006" inertia="6e-6" mesh="Finger_Distal"/>

    <xacro:igris_hand_finger_chain side="${side}" parent="${side}_Hand" part="Middle_Middle" child="Middle_Distal"
                                   joint_name="5_Joint_Middle_Middle" xyz="${side == 'Left' and '0.0085 -0.002 0.101' or '0.0085 0.002 0.101'}"
                                   rpy="${side == 'Left' and '0 0 3.141592654' or '0 0 0'}"
                                   axis="1 0 0" lower="0" upper="1.570796327"
                                   mass="0.008" inertia="8e-6" mesh="Finger_Middle"/>
    <xacro:igris_hand_finger_leaf side="${side}" parent="${side}_Middle_Middle" part="Middle_Distal"
                                  joint_name="6_Joint_Middle_Distal" xyz="0 -0.001 0.04" rpy="0 0 0"
                                  axis="1 0 0" lower="0" upper="1.570796327"
                                  mass="0.006" inertia="6e-6" mesh="Finger_Distal"/>

    <xacro:igris_hand_finger_chain side="${side}" parent="${side}_Hand" part="Ring_Middle" child="Ring_Distal"
                                   joint_name="7_Joint_Ring_Middle" xyz="${side == 'Left' and '-0.0135 -0.002 0.101' or '-0.0135 0.002 0.101'}"
                                   rpy="${side == 'Left' and '0 0 3.141592654' or '0 0 0'}"
                                   axis="1 0 0" lower="0" upper="1.570796327"
                                   mass="0.008" inertia="8e-6" mesh="Finger_Middle"/>
    <xacro:igris_hand_finger_leaf side="${side}" parent="${side}_Ring_Middle" part="Ring_Distal"
                                  joint_name="8_Joint_Ring_Distal" xyz="0 -0.001 0.04" rpy="0 0 0"
                                  axis="1 0 0" lower="0" upper="1.570796327"
                                  mass="0.006" inertia="6e-6" mesh="Finger_Distal"/>

    <xacro:igris_hand_finger_chain side="${side}" parent="${side}_Hand" part="Little_Middle" child="Little_Distal"
                                   joint_name="9_Joint_Little_Middle" xyz="${side == 'Left' and '-0.0355 -0.002 0.101' or '-0.0355 0.002 0.101'}"
                                   rpy="${side == 'Left' and '0 0 3.141592654' or '0 0 0'}"
                                   axis="1 0 0" lower="0" upper="1.570796327"
                                   mass="0.008" inertia="8e-6" mesh="Finger_Middle"/>
    <xacro:igris_hand_finger_leaf side="${side}" parent="${side}_Little_Middle" part="Little_Distal"
                                  joint_name="10_Joint_Little_Distal" xyz="0 -0.001 0.04" rpy="0 0 0"
                                  axis="1 0 0" lower="0" upper="1.570796327"
                                  mass="0.006" inertia="6e-6" mesh="Finger_Distal"/>
  </xacro:macro>

  <xacro:macro name="igris_hand_finger_chain" params="side parent part child joint_name xyz rpy axis lower upper mass inertia mesh">
    <link name="${side}_${part}">
      <inertial>
        <mass value="${mass}" />
        <origin xyz="0 0 0" />
        <inertia ixx="${inertia}" ixy="0" ixz="0" iyy="${inertia}" iyz="0" izz="${inertia}" />
      </inertial>
      <visual>
        <geometry>
          <mesh filename="${mesh_prefix}/hand/${mesh}.stl" scale="0.01 0.01 0.01" />
        </geometry>
        <material name="random">
          <color rgba="${random_rgba}" />
        </material>
      </visual>
      <collision>
        <geometry>
          <mesh filename="${mesh_prefix}/hand/${mesh}.stl" scale="0.01 0.01 0.01" />
        </geometry>
      </collision>
    </link>

    <joint name="${side}_${joint_name}" type="revolute">
      <parent link="${parent}" />
      <child link="${side}_${part}" />
      <origin xyz="${xyz}" rpy="${rpy}" />
      <axis xyz="${axis}" />
      <limit lower="${lower}" upper="${upper}" effort="1000" velocity="100.0" />
    </joint>
  </xacro:macro>

  <xacro:macro name="igris_hand_finger_leaf" params="side parent part joint_name xyz rpy axis lower upper mass inertia mesh">
    <link name="${side}_${part}">
      <inertial>
        <mass value="${mass}" />
        <origin xyz="0 0 0" />
        <inertia ixx="${inertia}" ixy="0" ixz="0" iyy="${inertia}" iyz="0" izz="${inertia}" />
      </inertial>
      <visual>
        <geometry>
          <mesh filename="${mesh_prefix}/hand/${mesh}.stl" scale="0.01 0.01 0.01" />
        </geometry>
        <material name="random">
          <color rgba="${random_rgba}" />
        </material>
      </visual>
      <collision>
        <geometry>
          <mesh filename="${mesh_prefix}/hand/${mesh}.stl" scale="0.01 0.01 0.01" />
        </geometry>
      </collision>
    </link>

    <joint name="${side}_${joint_name}" type="revolute">
      <parent link="${parent}" />
      <child link="${side}_${part}" />
      <origin xyz="${xyz}" rpy="${rpy}" />
      <axis xyz="${axis}" />
      <limit lower="${lower}" upper="${upper}" effort="1000" velocity="100.0" />
    </joint>
  </xacro:macro>

</robot>
