    <body name="r_ankle_flange_out" pos="0.00500 -0.03775 -0.08000" quat="1 0 0 0">
      <joint name="r_ankle_flange_out" type="hinge" ref="0.0" class="actuator_90" range="-0.63006386 0.609119909" limited="true" axis="0 1 0"/>
      <inertial pos="-0.01128 0.00742 -0.00003" mass="0.026" fullinertia="0.00001 0.00002 0.00001 0.00000 0.00000 0.00000"/>
      <geom name="r_ankle_flange_out_visual" pos="0 0 0" quat="1 0 0 0" material="random" type="mesh" mesh="r_ankle_flange_out" class="visual"/>
