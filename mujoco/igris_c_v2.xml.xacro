<?xml version="1.0"?>
<mujoco xmlns:xacro="http://www.ros.org/wiki/xacro" model="igris_c_v2">
  <!-- ===================== 0. Build parameters: xacro args + properties ===================== -->
  <xacro:arg name="base_type" default="torso"/>
  <xacro:arg name="parallel" default="false"/>
  <xacro:arg name="end_effector" default="dummy"/>
  <xacro:arg name="fixed" default="false"/>
  <xacro:property name="base_type_value" value="$(arg base_type)"/>
  <xacro:property name="end_effector_value" value="$(arg end_effector)"/>
  <xacro:property name="parallel_value" value="${'$(arg parallel)'.lower() == 'true'}"/>
  <xacro:property name="fixed_value" value="${'$(arg fixed)'.lower() == 'true'}"/>
  <!-- ===================== 1. Simulation header: compiler / size / option / default / asset ===================== -->
  <compiler angle="radian" meshdir="../meshes/igris_c_v2/" balanceinertia="false"/>
  <size njmax="8000" nconmax="4000"/>
  <option timestep="0.00033333333" iterations="100" tolerance="1e-7" solver="Newton" jacobian="dense" cone="elliptic" noslip_iterations="10" noslip_tolerance="1e-7"/>
  <default>
    <default class="robot">
      <default class="visual">
        <geom group="1" type="mesh" contype="0" conaffinity="0" density="0" rgba="0.9 0.9 0.9 1.0"/>
      </default>
      <default class="collision">
        <geom material="collision_material" rgba="1.0 0.28 0.1 1.0" condim="3" contype="1" conaffinity="1" priority="1" group="2" solref="0.01 1" friction="1 0.005 0.0001"/>
        <equality solimp="0.9 0.95 0.001 0.5 2" solref="0.001 1"/>
      </default>
    </default>
    <motor ctrllimited="true"/>
    <default class="actuator_150">
      <joint damping="0.5" frictionloss="0.5" limited="true" armature="0.2"/>
      <motor ctrlrange="-150.0 150.0"/>
    </default>
    <default class="actuator_120">
      <joint damping="0.5" frictionloss="2." limited="true" armature="0.12"/>
      <motor ctrlrange="-120.0 120.0"/>
    </default>
    <default class="actuator_90">
      <joint damping="0.0" frictionloss="0.1" limited="true" armature="0.1"/>
      <motor ctrlrange="-90.0 90.0"/>
    </default>
    <default class="actuator_60">
      <joint damping="0.5" frictionloss="0.54" limited="true" armature="0.019"/>
      <motor ctrlrange="-60.0 60.0"/>
    </default>
    <default class="actuator_8">
      <joint damping="0.0" frictionloss="0.264" limited="true" armature="0.01433"/>
      <motor ctrlrange="-8.0 8.0"/>
    </default>
    <default class="actuator_7">
      <joint damping="1.0" frictionloss="0.356" limited="true" armature="0.2488"/>
      <motor ctrlrange="-7.0 7.0"/>
    </default>
    <default class="passive">
      <joint damping="0.001" frictionloss="1e-4" limited="false" armature="1e-6"/>
    </default>
    <default class="slack">
      <joint damping="0.001" frictionloss="1e-4" limited="true" armature="1e-6"/>
    </default>
  </default>
  <asset>
    <material name="random" rgba="0.0706 0.0706 0.0706 0.7"/>
    <material name="default_material" rgba="0.7 0.7 0.7 1"/>
    <material name="collision_material" rgba="1.0 0.28 0.1 0.9"/>
    <mesh name="torso" file="torso.stl" scale="0.01 0.01 0.01"/>
    <mesh name="waist_frame" file="waist_frame.stl" scale="0.01 0.01 0.01"/>
    <mesh name="waist_follower" file="waist_follower.stl" scale="0.01 0.01 0.01"/>
    <mesh name="pelvis" file="pelvis.stl" scale="0.01 0.01 0.01"/>
    <mesh name="pelvis_upper_front" file="pelvis_upper_front.stl" scale="0.01 0.01 0.01"/>
    <mesh name="pelvis_upper_back" file="pelvis_upper_back.stl" scale="0.01 0.01 0.01"/>
    <mesh name="pelvis_lower" file="pelvis_lower.stl" scale="0.01 0.01 0.01"/>
    <mesh name="neck" file="neck.stl" scale="0.01 0.01 0.01"/>
    <mesh name="head" file="head.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_hip_frame" file="l_hip_frame.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_hip_bracket" file="l_hip_bracket.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_hip_yaw_collision" file="upper_leg_collision.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_upper_leg" file="l_upper_leg.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_lower_leg" file="l_lower_leg.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_ankle_frame" file="l_ankle_frame.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_foot_original_collision" file="foot_v3_collision.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_foot_original" file="foot_v3_visual.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_hip_frame" file="r_hip_frame.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_hip_bracket" file="r_hip_bracket.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_hip_yaw_collision" file="upper_leg_collision.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_upper_leg" file="r_upper_leg.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_lower_leg" file="r_lower_leg.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_ankle_frame" file="r_ankle_frame.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_foot_original_collision" file="foot_v3_collision.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_foot_original" file="foot_v3_visual.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_shoulder_frame" file="l_shoulder_frame.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_shoulder_bracket" file="l_shoulder_bracket.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_upper_arm" file="l_upper_arm.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_elbow_bracket" file="l_elbow_bracket.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_forearm" file="l_forearm.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_wrist_rod" file="l_wrist_rod.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_wrist_connector" file="l_wrist_connector.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_shoulder_frame" file="r_shoulder_frame.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_shoulder_bracket" file="r_shoulder_bracket.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_upper_arm" file="r_upper_arm.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_elbow_bracket" file="r_elbow_bracket.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_forearm" file="r_forearm.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_wrist_rod" file="r_wrist_rod.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_wrist_connector" file="r_wrist_connector.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_waist_flange" file="l_waist_flange.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_waist_flange" file="r_waist_flange.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_waist_parallel" file="l_waist_parallel.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_waist_parallel" file="r_waist_parallel.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_ankle_flange_out" file="l_ankle_flange_out.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_ankle_flange_in" file="l_ankle_flange_in.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_ankle_parallel_out" file="l_ankle_parallel_out.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_ankle_parallel_in" file="l_ankle_parallel_in.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_ankle_flange_out" file="r_ankle_flange_out.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_ankle_flange_in" file="r_ankle_flange_in.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_ankle_parallel_out" file="r_ankle_parallel_out.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_ankle_parallel_in" file="r_ankle_parallel_in.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_wrist_flange_front" file="l_wrist_flange_front.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_wrist_flange_back" file="l_wrist_flange_back.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_wrist_parallel_front" file="l_wrist_parallel_front.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_wrist_parallel_back" file="l_wrist_parallel_back.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_wrist_universal_front" file="l_wrist_universal_front.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_wrist_universal_back" file="l_wrist_universal_back.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_wrist_flange_front" file="r_wrist_flange_front.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_wrist_flange_back" file="r_wrist_flange_back.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_wrist_parallel_front" file="r_wrist_parallel_front.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_wrist_parallel_back" file="r_wrist_parallel_back.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_wrist_universal_front" file="r_wrist_universal_front.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_wrist_universal_back" file="r_wrist_universal_back.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_wrist_motor_output_front" file="l_wrist_motor_output_front.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_wrist_coupler_front" file="l_wrist_coupler_front.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_wrist_motor_output_back" file="l_wrist_motor_output_back.stl" scale="0.01 0.01 0.01"/>
    <mesh name="l_wrist_coupler_back" file="l_wrist_coupler_back.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_wrist_motor_output_front" file="r_wrist_motor_output_front.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_wrist_coupler_front" file="r_wrist_coupler_front.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_wrist_motor_output_back" file="r_wrist_motor_output_back.stl" scale="0.01 0.01 0.01"/>
    <mesh name="r_wrist_coupler_back" file="r_wrist_coupler_back.stl" scale="0.01 0.01 0.01"/>
    <texture type="skybox" builtin="gradient" width="128" height="128" rgb1="1.0 1.0 1.0" rgb2="0.4 0.4 0.4"/>
    <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1="0.9 0.9 0.9" rgb2=".85 .85 .85"/>
    <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance=".2"/>
    <!-- end_effector meshes: declared only for the selected end_effector. -->
    <xacro:if value="${end_effector_value == 'hand'}">
      <mesh name="l_palm" file="../igris_c_end_effector/hand/l_palm.stl" scale="0.01 0.01 0.01"/>
      <mesh name="r_palm" file="../igris_c_end_effector/hand/r_palm.stl" scale="0.01 0.01 0.01"/>
      <mesh name="l_thumb_proximal" file="../igris_c_end_effector/hand/l_thumb_proximal.stl" scale="0.01 0.01 0.01"/>
      <mesh name="l_thumb_middle" file="../igris_c_end_effector/hand/l_thumb_middle.stl" scale="0.01 0.01 0.01"/>
      <mesh name="l_thumb_distal" file="../igris_c_end_effector/hand/l_thumb_distal.stl" scale="0.01 0.01 0.01"/>
      <mesh name="r_thumb_proximal" file="../igris_c_end_effector/hand/r_thumb_proximal.stl" scale="0.01 0.01 0.01"/>
      <mesh name="r_thumb_middle" file="../igris_c_end_effector/hand/r_thumb_middle.stl" scale="0.01 0.01 0.01"/>
      <mesh name="r_thumb_distal" file="../igris_c_end_effector/hand/r_thumb_distal.stl" scale="0.01 0.01 0.01"/>
      <mesh name="finger_middle" file="../igris_c_end_effector/hand/finger_middle.stl" scale="0.01 0.01 0.01"/>
      <mesh name="finger_distal" file="../igris_c_end_effector/hand/finger_distal.stl" scale="0.01 0.01 0.01"/>
    </xacro:if>
    <xacro:if value="${end_effector_value == 'magnet'}">
      <mesh name="l_magnet" file="../igris_c_end_effector/magnet/l_magnet_gripper.stl" scale="0.01 0.01 0.01"/>
      <mesh name="r_magnet" file="../igris_c_end_effector/magnet/r_magnet_gripper.stl" scale="0.01 0.01 0.01"/>
    </xacro:if>
    <xacro:if value="${end_effector_value == '1dof'}">
      <mesh name="l_1_dof_gripper_fixed" file="../igris_c_end_effector/1_dof_gripper/l_1_dof_gripper_fixed.stl" scale="0.01 0.01 0.01"/>
      <mesh name="l_1_dof_gripper_moving" file="../igris_c_end_effector/1_dof_gripper/l_1_dof_gripper_moving.stl" scale="0.01 0.01 0.01"/>
      <mesh name="r_1_dof_gripper_fixed" file="../igris_c_end_effector/1_dof_gripper/r_1_dof_gripper_fixed.stl" scale="0.01 0.01 0.01"/>
      <mesh name="r_1_dof_gripper_moving" file="../igris_c_end_effector/1_dof_gripper/r_1_dof_gripper_moving.stl" scale="0.01 0.01 0.01"/>
    </xacro:if>
  </asset>
  <!-- ===================== 2. Reusable macro definitions ===================== -->
  <xacro:include filename="igris_c_lowerarm_module.xml.xacro"/>
  <xacro:macro name="igris_c_l_parallel_ankle_block">
    <body name="l_ankle_frame" pos="0.005 0 -0.34" quat="1 0 0 0">
      <joint name="l_ankle_pitch" type="hinge" ref="0.0" class="passive" range="-0.698131701 0.698131701" limited="true" axis="0 1 0"/>
      <joint name="l_ankle_pitch_backlash" type="hinge" ref="0.0" class="slack" range="-0.01 0.01" axis="0 1 0"/>
      <inertial pos="0.00000 0.00000 0.00000" mass="0.084" fullinertia="3e-05 2e-05 3e-05 0 0 0"/>
      <geom name="l_ankle_frame_visual" pos="0 0 0" quat="1 0 0 0" material="random" type="mesh" mesh="l_ankle_frame" class="visual"/>
      <body name="l_foot_original" pos="0 0 0" quat="1 0 0 0">
        <joint name="l_ankle_roll" type="hinge" ref="0.0" class="passive" range="-0.34906585 0.34906585" limited="true" axis="1 0 0"/>
        <joint name="l_ankle_roll_backlash" type="hinge" ref="0.0" class="slack" range="-0.01 0.01" axis="1 0 0"/>
        <inertial pos="0.02167 0.00000 -0.05193" mass="0.579" fullinertia="0.00045 0.00166 0.00158 0.00000 0.00024 0.00000"/>
        <geom name="l_foot_original_collision" pos="0.048 0 -0.0685" quat="1 0 0 0" type="box" size="0.1 0.035 0.0025" class="collision" rgba="0.1 0.1 0.1 1"/>
        <geom name="l_foot_original_visual" pos="0.048 0 -0.0685" quat="1 0 0 0" type="box" size="0.1 0.035 0.0025" class="visual"/>
      </body>
    </body>
    <body name="l_ankle_flange_out" pos="0.00500 0.03775 -0.08000" quat="1 0 0 0">
      <joint name="l_ankle_flange_out" type="hinge" ref="0.0" class="actuator_90" range="-0.63006386 0.609119909" limited="true" axis="0 1 0"/>
      <inertial pos="-0.01128 -0.00742 -0.00003" mass="0.026" fullinertia="0.00001 0.00002 0.00001 0 0 0"/>
      <geom name="l_ankle_flange_out_visual" pos="0 0 0" quat="1 0 0 0" material="random" type="mesh" mesh="l_ankle_flange_out" class="visual"/>
      <body name="l_ankle_parallel_out" pos="-0.03750 0.00000 -0.00011" quat="1 0 0 0">
        <joint name="l_ankle_parallel_out" type="ball" ref="0.0" class="passive"/>
        <inertial pos="0.00183 -0.00357 -0.13606" mass="0.130" fullinertia="0.00092 0.00092 0.00001 0.00000 0.000001 -0.00002"/>
        <geom name="l_ankle_parallel_out_visual" pos="0 0 0" quat="1 0 0 0" material="random" type="mesh" mesh="l_ankle_parallel_out" class="visual"/>
      </body>
    </body>
    <body name="l_ankle_flange_in" pos="0.00500 -0.03775 -0.18800" quat="1 0 0 0">
      <joint name="l_ankle_flange_in" type="hinge" ref="0.0" class="actuator_90" range="-0.617846555 0.523598776" limited="true" axis="0 1 0"/>
      <inertial pos="-0.01128 0.00742 -0.00006" mass="0.026" fullinertia="0.00001 0.00002 0.00001 0 0 0"/>
      <geom name="l_ankle_flange_in_visual" pos="0 0 0" quat="1 0 0 0" material="random" type="mesh" mesh="l_ankle_flange_in" class="visual"/>
      <body name="l_ankle_parallel_in" pos="-0.03750 0.00000 -0.00019" quat="1 0 0 0">
        <joint name="l_ankle_parallel_in" type="ball" ref="0.0" class="passive"/>
        <inertial pos="0.00187 0.00365 -0.08089" mass="0.083" fullinertia="0.00022 0.00022 0.00001 0.00000 0.00000 0.00001"/>
        <geom name="l_ankle_parallel_in_visual" pos="0 0 0" quat="1 0 0 0" material="random" type="mesh" mesh="l_ankle_parallel_in" class="visual"/>
      </body>
    </body>
  </xacro:macro>
  <xacro:macro name="igris_c_r_parallel_ankle_block">
    <body name="r_ankle_frame" pos="0.005 0 -0.34" quat="1 0 0 0">
      <joint name="r_ankle_pitch" type="hinge" ref="0.0" class="passive" range="-0.698131701 0.698131701" limited="true" axis="0 1 0"/>
