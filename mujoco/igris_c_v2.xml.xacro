        <inertial pos="0.00183 0.00357 -0.13606" mass="0.130" fullinertia="0.00092 0.00092 0.00001 0.00000 0.000001 0.00002"/>
        <geom name="r_ankle_parallel_out_visual" pos="0 0 0" quat="1 0 0 0" material="random" type="mesh" mesh="r_ankle_parallel_out" class="visual"/>
      </body>
    </body>
    <body name="r_ankle_flange_in" pos="0.00500 0.03775 -0.18800" quat="1 0 0 0">
      <joint name="r_ankle_flange_in" type="hinge" ref="0.0" class="actuator_90" range="-0.617846555 0.523598776" limited="true" axis="0 1 0"/>
      <inertial pos="-0.01128 -0.00742 -0.00006" mass="0.026" fullinertia="0.00001 0.00002 0.00001 0.00000 0.00000 0.00000"/>
      <geom name="r_ankle_flange_in_visual" pos="0 0 0" quat="1 0 0 0" material="random" type="mesh" mesh="r_ankle_flange_in" class="visual"/>
      <body name="r_ankle_parallel_in" pos="-0.03750 0.00000 -0.00019" quat="1 0 0 0">
        <joint name="r_ankle_parallel_in" type="ball" ref="0.0" class="passive"/>
        <inertial pos="0.00187 -0.00365 -0.08089" mass="0.083" fullinertia="0.00022 0.00022 0.00001 0.00000 0.00000 -0.00001"/>
        <geom name="r_ankle_parallel_in_visual" pos="0 0 0" quat="1 0 0 0" material="random" type="mesh" mesh="r_ankle_parallel_in" class="visual"/>
      </body>
    </body>
  </xacro:macro>
  <xacro:macro name="igris_c_torso_parallel_waist_block">
    <body name="l_waist_flange" pos="0 0.0905 0" quat="1 0 0 0">
      <joint name="l_waist_flange" type="hinge" ref="0.0" class="actuator_60" range="-0.34 0.87" limited="true" axis="0 1 0"/>
      <inertial pos="-0.01470 -0.00883 -0.00167" mass="0.043" fullinertia="0.00001 0.00004 0.00003 0 0 0"/>
