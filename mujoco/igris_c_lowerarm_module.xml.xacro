  </xacro:macro>
  <xacro:macro name="igris_c_lowerarm_module" params="side parallel">
    <xacro:if value="${side == 'left'}">
      <body name="l_forearm" pos="-0.01 0 -0.05" quat="1 0 0 0">
        <joint name="l_wrist_yaw" type="hinge" ref="0.0" class="actuator_8" range="-1.570796327 1.570796327" axis="0 0 1"/>
        <joint name="l_wrist_yaw_backlash" type="hinge" ref="0.0" class="slack" range="-0.01 0.01" axis="0 0 1"/>
        <inertial pos="0.01024 -0.00369 -0.11953" mass="2.428" fullinertia="0.00919 0.00944 0.00179 0.00002 -0.00063 -0.00017"/>
        <geom name="l_forearm_collision" pos="0 0 0" quat="1 0 0 0" type="mesh" mesh="l_forearm" class="collision"/>
        <geom name="l_forearm_visual" pos="0 0 0" quat="1 0 0 0" material="random" type="mesh" mesh="l_forearm" class="visual"/>
        <xacro:if value="${end_effector_value == 'hand'}">
        </xacro:if>
        <xacro:if value="${end_effector_value == 'dummy'}">
          <geom name="l_hand_dummy_collision" pos="0 0.0109 -0.3" quat="1 0 0 0" type="sphere" size="0.05" density="0" class="collision"/>
          <geom name="l_hand_dummy_visual" pos="0 0.0109 -0.3" quat="1 0 0 0" type="sphere" size="0.05" material="random" class="visual"/>
        </xacro:if>
        <xacro:if value="${parallel}">
          <xacro:igris_c_l_parallel_wrist_forearm_block/>
        </xacro:if>
        <body name="l_wrist_rod" pos="0 -0.005 -0.2395" quat="1 0 0 0">
          <xacro:if value="${parallel}">
            <joint name="l_wrist_roll" type="hinge" ref="0.0" class="passive" range="-1.221730476 0.872664626" limited="true" axis="1 0 0"/>
            <joint name="l_wrist_roll_backlash" type="hinge" ref="0.0" class="slack" range="-0.01 0.01" axis="1 0 0"/>
          </xacro:if>
          <xacro:unless value="${parallel}">
            <joint name="l_wrist_roll" type="hinge" ref="0.0" class="actuator_8" range="-1.221730476 0.872664626" limited="true" axis="1 0 0"/>
            <joint name="l_wrist_roll_backlash" type="hinge" ref="0.0" class="slack" range="-0.01 0.01" axis="1 0 0"/>
          </xacro:unless>
          <inertial pos="0 0.00604 0.00031" mass="0.012" fullinertia="0.00001 0.00001 0.00001 0 0 0"/>
          <geom name="l_wrist_rod_visual" pos="0 0 0" quat="1 0 0 0" material="random" type="mesh" mesh="l_wrist_rod" class="visual"/>
          <body name="l_wrist_connector" pos="0 0 0" quat="1 0 0 0">
            <xacro:if value="${parallel}">
              <joint name="l_wrist_pitch" type="hinge" ref="0.0" class="passive" range="-0.698131701 0.698131701" limited="true" axis="0 1 0"/>
              <joint name="l_wrist_pitch_backlash" type="hinge" ref="0.0" class="slack" range="-0.01 0.01" axis="0 1 0"/>
            </xacro:if>
            <xacro:unless value="${parallel}">
              <joint name="l_wrist_pitch" type="hinge" ref="0.0" class="actuator_8" range="-0.698131701 0.698131701" limited="true" axis="0 1 0"/>
              <joint name="l_wrist_pitch_backlash" type="hinge" ref="0.0" class="slack" range="-0.01 0.01" axis="0 1 0"/>
            </xacro:unless>
            <inertial pos="0 0.01203 -0.02699" mass="0.032" fullinertia="0.00001 0.00001 0.00001 0 0 0"/>
            <geom name="l_wrist_connector_visual" pos="0 0 0" quat="1 0 0 0" material="random" type="mesh" mesh="l_wrist_connector" class="visual"/>
            <xacro:if value="${end_effector_value == 'hand' and not parallel}">
            </xacro:if>
            <xacro:if value="${end_effector_value == 'dummy'}">
              <body name="l_hand_dummy" pos="0 0.0109 -0.024" quat="0 1 0 0">
                <inertial pos="0.00910 0.00371 0.07839" mass="0.150" fullinertia="0.00081 0.00117 0.00042 -0.00004 0.00012 0.00005"/>
              </body>
            </xacro:if>
            <xacro:if value="${end_effector_value == 'none'}">
              <xacro:igris_c_no_end_effector_block/>
            </xacro:if>
            <xacro:if value="${end_effector_value == 'hand'}">
              <xacro:igris_c_l_hand_end_effector_block/>
            </xacro:if>
            <xacro:if value="${end_effector_value == 'magnet'}">
              <xacro:igris_c_l_magnet_end_effector_block/>
            </xacro:if>
            <xacro:if value="${end_effector_value == '1dof'}">
              <xacro:igris_c_l_1dof_gripper_end_effector_block/>
            </xacro:if>
            <xacro:if value="${parallel}">
              <xacro:igris_c_l_parallel_wrist_connector_block/>
            </xacro:if>
          </body>
        </body>
      </body>
    </xacro:if>
    <xacro:if value="${side == 'right'}">
      <body name="r_forearm" pos="-0.01 0 -0.05" quat="1 0 0 0">
        <joint name="r_wrist_yaw" type="hinge" ref="0.0" class="actuator_8" range="-1.570796327 1.570796327" axis="0 0 1"/>
        <joint name="r_wrist_yaw_backlash" type="hinge" ref="0.0" class="slack" range="-0.01 0.01" axis="0 0 1"/>
        <inertial pos="0.01024 0.00369 -0.11953" mass="2.428" fullinertia="0.00919 0.00944 0.00179 -0.00002 -0.00063 0.00017"/>
        <geom name="r_forearm_collision" pos="0 0 0" quat="1 0 0 0" type="mesh" mesh="r_forearm" class="collision"/>
        <geom name="r_forearm_visual" pos="0 0 0" quat="1 0 0 0" material="random" type="mesh" mesh="r_forearm" class="visual"/>
        <xacro:if value="${end_effector_value == 'dummy'}">
          <geom name="r_hand_dummy_collision" pos="0 -0.0109 -0.3" quat="1 0 0 0" type="sphere" size="0.05" density="0" class="collision"/>
          <geom name="r_hand_dummy_visual" pos="0 -0.0109 -0.3" quat="1 0 0 0" type="sphere" size="0.05" material="random" class="visual"/>
        </xacro:if>
        <xacro:if value="${parallel}">
          <xacro:igris_c_r_parallel_wrist_forearm_block/>
        </xacro:if>
        <body name="r_wrist_rod" pos="0 0.005 -0.2395" quat="1 0 0 0">
          <xacro:if value="${parallel}">
            <joint name="r_wrist_roll" type="hinge" ref="0.0" class="passive" range="-0.872664626 1.221730476" limited="true" axis="1 0 0"/>
            <joint name="r_wrist_roll_backlash" type="hinge" ref="0.0" class="slack" range="-0.01 0.01" axis="1 0 0"/>
          </xacro:if>
          <xacro:unless value="${parallel}">
            <joint name="r_wrist_roll" type="hinge" ref="0.0" class="actuator_8" range="-0.872664626 1.221730476" limited="true" axis="1 0 0"/>
            <joint name="r_wrist_roll_backlash" type="hinge" ref="0.0" class="slack" range="-0.01 0.01" axis="1 0 0"/>
          </xacro:unless>
          <inertial pos="0 -0.00604 0.00031" mass="0.012" fullinertia="0.00001 0.00001 0.00001 0 0 0"/>
          <geom name="r_wrist_rod_visual" pos="0 0 0" quat="1 0 0 0" material="random" type="mesh" mesh="r_wrist_rod" class="visual"/>
          <body name="r_wrist_connector" pos="0 0 0" quat="1 0 0 0">
            <xacro:if value="${parallel}">
              <joint name="r_wrist_pitch" type="hinge" ref="0.0" class="passive" range="-0.698131701 0.698131701" limited="true" axis="0 1 0"/>
              <joint name="r_wrist_pitch_backlash" type="hinge" ref="0.0" class="slack" range="-0.01 0.01" axis="0 1 0"/>
            </xacro:if>
            <xacro:unless value="${parallel}">
              <joint name="r_wrist_pitch" type="hinge" ref="0.0" class="actuator_8" range="-0.698131701 0.698131701" limited="true" axis="0 1 0"/>
              <joint name="r_wrist_pitch_backlash" type="hinge" ref="0.0" class="slack" range="-0.01 0.01" axis="0 1 0"/>
            </xacro:unless>
            <inertial pos="0 -0.01203 -0.02699" mass="0.032" fullinertia="0.00001 0.00001 0.00001 0 0 0"/>
            <geom name="r_wrist_connector_visual" pos="0 0 0" quat="1 0 0 0" material="random" type="mesh" mesh="r_wrist_connector" class="visual"/>
            <xacro:if value="${end_effector_value == 'dummy'}">
              <body name="r_hand_dummy" pos="0 -0.0109 -0.024" quat="0 1 0 0">
                <inertial pos="0.00910 -0.00371 0.07839" mass="0.150" fullinertia="0.00081 0.00117 0.00042 0.00004 0.00012 -0.00005"/>
              </body>
            </xacro:if>
            <xacro:if value="${end_effector_value == 'none'}">
              <xacro:igris_c_no_end_effector_block/>
            </xacro:if>
            <xacro:if value="${end_effector_value == 'hand'}">
              <xacro:igris_c_r_hand_end_effector_block/>
            </xacro:if>
            <xacro:if value="${end_effector_value == 'magnet'}">
              <xacro:igris_c_r_magnet_end_effector_block/>
            </xacro:if>
            <xacro:if value="${end_effector_value == '1dof'}">
              <xacro:igris_c_r_1dof_gripper_end_effector_block/>
            </xacro:if>
            <xacro:if value="${parallel}">
              <xacro:igris_c_r_parallel_wrist_connector_block/>
            </xacro:if>
          </body>
        </body>
      </body>
    </xacro:if>
  </xacro:macro>
</mujoco>
